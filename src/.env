# Configurações da API
HOST=0.0.0.0
PORT=8443
RELOAD=True # True ou ''

# Configurações banco de dados
DB_SGDB=mysql # sqlite - SQLite, mysql - MySQL, mssql - SQL Server
DB_NAME=comandas_db
DB_HOST=db # :3306 :5432
DB_USER=andrenicsx
DB_PASS=08112006
DB_PORT=3306

# Configurações Segurança da API - JWT
# Para obter uma cadeia de caracteres execute no gitbash: openssl rand -hex 32
# Ou crie uma chave secreta super forte, devendo mudar em produção
# Não utilize a do exemplo!
SECRET_KEY=08112006
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Configurações de Rate Limiting
# Muito restritivo - Exemplo: login, refresh, logout, exclusões, operações sensíveis
RATE_LIMIT_CRITICAL=15/minute
# Moderado - Exemplo: listagens, buscas por ID
RATE_LIMIT_MODERATE=100/minute
# Restritivo - Exemplo: criações, atualizações
RATE_LIMIT_RESTRICTIVE=20/minute
# Baixo - Exemplo: health checks, endpoints de sistema
RATE_LIMIT_LOW=200/minute
# Padrão para endpoints não especificados
RATE_LIMIT_DEFAULT=50/minute

# Configuração de CORS
# Domínios permitidos separados por vírgula. Ex: http://localhost:3000,http://localhost:5173
# Para permitir todos temporariamente no dev, use *
CORS_ORIGINS=*